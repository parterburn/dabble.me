{
  "name": "dabble.me",
  "version": "1.0.0",
  "description": "Private email journaling & daily reflection.",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "font-awesome": "^4.7.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tippy.js": "^6.3.7"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./app/frontend/stylesheets/marketing.tailwind.css -o ./public/marketing.css --minify",
    "watch:css": "tailwindcss -i ./app/frontend/stylesheets/marketing.tailwind.css -o ./public/marketing.css --watch",
    "build:css:app": "tailwindcss -i ./app/frontend/stylesheets/application.tailwind.css -o ./public/application-tailwind.css --minify",
    "watch:css:app": "tailwindcss -i ./app/frontend/stylesheets/application.tailwind.css -o ./public/application-tailwind.css --watch",
    "build:css:all": "npm run build:css && npm run build:css:app",
    "heroku-postbuild": "npm run build:css:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parterburn/dabble.me.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/parterburn/dabble.me/issues"
  },
  "homepage": "https://github.com/parterburn/dabble.me#readme"
}
