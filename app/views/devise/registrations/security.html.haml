- title 'Account Settings — Dabble me.'

.row
  .col-md-8.col-md-offset-2
    %h3 ACCOUNT SECURITY
    %br

  = form_for(user, url: registration_path(user), html: { method: :put }) do |f|
    .col-md-8.col-md-offset-2
      = f.label :email
      = f.email_field :email, class: "form-control"
      %br

    - if devise_mapping.confirmable? && resource.pending_reconfirmation?
      .col-md-8.col-md-offset-2
        Currently waiting confirmation for: #{resource.unconfirmed_email}

    .col-md-4.col-md-offset-2
      = f.label :password, "New Password"
      = f.password_field :password, autocomplete: "off", class: "form-control"
      %br

    .col-md-4
      = f.label :password_confirmation, "New Password Confirmation"
      = f.password_field :password_confirmation, autocomplete: "off", class: "form-control"
      %br

    .col-md-8.col-md-offset-2
      %label{style: 'margin-bottom: 10px;'} Additional Security
      %br
      %div{style: 'margin-bottom: 15px;'}
        %button.btn.btn-default.btn-sm#add-passkey{type: "button"}
          Add Passkey

        = link_to user_otp_token_path do
          %button.btn.btn-default.btn-sm#add-two-factor{type: "button"}
            - if current_user.otp_enabled?
              %span{class: "text-success"}
                ✅ Change Two-Factor Authentication
            -else
              Setup Two-Factor Authentication

      - if current_user.webauthn_credentials.any?
        %table.table
          %thead
            %tr
              %th Passkey
              %th Added
              %th
          %tbody
            - current_user.webauthn_credentials.each do |credential|
              %tr
                %td= credential.nickname
                %td= credential.created_at.strftime("%b %d, %Y")
                %td.text-right= link_to "Remove", passkeys_registration_path(credential), method: :delete, data: { confirm: "Are you sure?" }, class: "text-danger"

    = render "oauth_connected_apps"

    .col-md-8.col-md-offset-2{style: "margin-top: 1.5rem;"}
      .well{style: 'background-color: #E8E8E2; padding: 15px 20px;'}
        = f.label :current_password
        to confirm email or password changes above
        = f.password_field :current_password, autocomplete: "off", class: "form-control"

    .col-md-8.col-md-offset-2{style: "margin-top: 1rem;"}
      = f.submit "Update Security", class: "btn btn-primary form-control j-edit-security", name: "submit_method", type: :submit

    .clearfix

    .col-md-8.col-md-offset-2
      %p.text-center.text-muted{style: "margin-top: 1.5rem;"}
        To permanently delete your account and #{pluralize(current_user.entries.count, "entry")},
        #{link_to "use the delete account page", delete_account_path, class: "text-danger"}.
