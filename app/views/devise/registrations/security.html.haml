- title 'Account Settings — Dabble me.'

.row
  .col-md-8.col-md-offset-2
    %h3 ACCOUNT SECURITY
    %br

  = form_for(user, url: registration_path(user), html: { method: :put }) do |f|
    .col-md-8.col-md-offset-2
      = f.label :email
      = f.email_field :email, class: "form-control"
      %br

    - if devise_mapping.confirmable? && resource.pending_reconfirmation?
      .col-md-8.col-md-offset-2
        Currently waiting confirmation for: #{resource.unconfirmed_email}

    .col-md-4.col-md-offset-2
      = f.label :password, "New Password"
      = f.password_field :password, autocomplete: "off", class: "form-control"
      %br

    .col-md-4
      = f.label :password_confirmation, "New Password Confirmation"
      = f.password_field :password_confirmation, autocomplete: "off", class: "form-control"
      %br

    .col-md-8.col-md-offset-2
      %label{style: 'margin-bottom: 10px;'} Additional Security
      %br
      %div{style: 'margin-bottom: 15px;'}
        %button.btn.btn-default.btn-sm#add-passkey{type: "button"}
          Add Passkey

        = link_to user_otp_token_path do
          %button.btn.btn-default.btn-sm#add-two-factor{type: "button"}
            - if current_user.otp_enabled?
              %span{class: "text-success"}
                ✅ Change Two-Factor Authentication
            -else
              Setup Two-Factor Authentication

      - if current_user.webauthn_credentials.any?
        %table.table
          %thead
            %tr
              %th Passkey
              %th Added
              %th
          %tbody
            - current_user.webauthn_credentials.each do |credential|
              %tr
                %td= credential.nickname
                %td= credential.created_at.strftime("%b %d, %Y")
                %td= link_to "Remove", passkeys_registration_path(credential), method: :delete, data: { confirm: "Are you sure?" }, class: "text-danger"

    .col-md-8.col-md-offset-2
      .well{style: 'background-color: #E8E8E2; padding: 15px 20px; margin-top: 10px;'}
        %h4{style: 'margin-top: 0;'} MCP access to your journal
        - if current_user.is_free?
          %p
            MCP access is available for
            = link_to 'Dabble Me PRO', subscribe_path, class: 'alert-link'
            only.
        - elsif !current_user.mcp_security_requirements_met?
          %p
            To enable MCP, first add a passkey or set up two-factor authentication.
            MCP stays disabled unless your account has stronger login protection.
        - else
          %p
            MCP is opt-in and read-only. It only exposes your own entries over a bearer token that is shown once when generated.
          - endpoint = ApplicationHelper.mcp_endpoint
          %p
            Endpoint:
            %code= endpoint

          - if flash[:mcp_token].present?
            .alert.alert-warning.force-links
              %strong Copy this token now.
              It will not be shown again after you leave this page.
              %div{style: 'margin-top: 8px;'}
                %code{style: 'word-break: break-all;'}= flash[:mcp_token]
              %div{style: 'margin-top: 8px;'}
                %button.btn.btn-default.btn-sm.j-copy-to-clipboard{type: 'button', data: { content: flash[:mcp_token] }}
                  Copy token

          - if current_user.mcp_available?
            %p
              Status:
              %span.text-success Enabled
              - if current_user.mcp_last_used_at.present?
                %br
                Last used:
                = current_user.mcp_last_used_at.strftime('%b %-d, %Y at %-l:%M %p %Z')
              - if current_user.mcp_token_generated_at.present?
                %br
                Token created:
                = current_user.mcp_token_generated_at.strftime('%b %-d, %Y at %-l:%M %p %Z')
          - else
            %p
              Status:
              %span.text-muted Disabled

          .row
            .col-sm-6
              = form_with url: generate_mcp_token_path, method: :post, local: true do |mcp_form|
                = mcp_form.hidden_field :current_password, name: 'user[current_password]', value: ''
                = mcp_form.submit 'Generate / Regenerate MCP token', class: 'btn btn-primary form-control', data: { confirm: 'Generate a new MCP token? Any previous token will stop working immediately.' }, onclick: "this.form.querySelector('input[name=\"user[current_password]\"]').value = document.getElementById('user_current_password').value;"
            .col-sm-6
              = button_to 'Revoke MCP token', revoke_mcp_token_path, method: :delete, class: 'btn btn-default form-control', disabled: !current_user.mcp_enabled?

          %hr
          %p
            Example MCP config:
          %pre{style: 'white-space: pre-wrap;'}= "{\n  \"url\": \"#{endpoint}\",\n  \"headers\": {\n    \"Authorization\": \"Bearer YOUR_DABBLE_ME_MCP_TOKEN\"\n  }\n}"
          %p
            Quick smoke test:
          %pre{style: 'white-space: pre-wrap;'}= "curl -X POST #{endpoint} \\\n  -H 'Content-Type: application/json' \\\n  -H 'Authorization: Bearer YOUR_DABBLE_ME_MCP_TOKEN' \\\n  -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"}'"

    .col-md-8.col-md-offset-2
      .well{style: 'background-color: #E8E8E2; padding: 15px 20px;'}
        = f.label :current_password
        to confirm your changes
        = f.password_field :current_password, autocomplete: "off", class: "form-control"

    .col-md-8.col-md-offset-2
      = f.submit "Update Security", class: "btn btn-primary form-control j-edit-security", name: "submit_method", type: :submit

    .clearfix

    .col-md-8.col-md-offset-2
      %br
      - show_warning = ""
      - if current_user.is_pro? && (current_user.plan_type_unlinked != "Stripe" || current_user.stripe_id.blank?)
        - show_warning = " You will need to cancel your subscription *separately* at #{current_user.plan_type_unlinked}."
      .text-center= f.button "Delete your account along with #{pluralize(current_user.entries.count,'associated entry')}", class: "btn btn-link j-delete-user", style: "color: #a41100;", name: "submit_method", value: "delete account", type: :submit, data: { confirm: "Are you sure? This will **permanently delete** your account and #{pluralize(current_user.entries.count,'entry')}. There is no undo.#{show_warning}" }
