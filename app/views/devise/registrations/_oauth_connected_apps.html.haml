.col-md-8.col-md-offset-2
  %label{style: 'margin-bottom: 10px;'} Connected Apps
  - if @oauth_applications.any?
    %p.small.text-muted{style: "margin-bottom: 12px;"}
      These tools can call Dabble Me on your behalf until you revoke them.
    .table-responsive
      %table.table
        %thead
          %tr
            %th Application
            %th Added
            %th
        %tbody
          - @oauth_applications.each do |application|
            %tr
              %td= application.name
              %td= application.created_at.strftime("%b %d, %Y")
              %td.text-right
                = link_to "Remove",oauth_authorized_application_path(application), method: :delete, data: { confirm: "Are you sure?" }, class: "text-danger"
  - else
    %p.text-muted{style: "margin-bottom: 12px;"}
      Connect to apps like Claude by adding a #{link_to "Custom MCP connector", support_path(anchor: "mcp"), class: "text-accent hover:text-primary underline font-semibold"}.