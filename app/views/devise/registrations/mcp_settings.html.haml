- title "MCP settings — Dabble me."

- mcp_server_url = mcp_url(**ApplicationHelper.mcp_url_options)
- date_fmt = t("doorkeeper.authorized_applications.index.date_format", default: "%Y-%m-%d %H:%M:%S")

.row
  .col-md-8.col-md-offset-2
    %h3 MCP settings

    .well{style: "background-color: #E8E8E2; padding: 15px 20px; margin-top: 10px;"}
      - if current_user.is_free?
        %p
          MCP lets compatible apps use your journal after you sign in with Dabble Me.
          = link_to "Upgrade to PRO", subscribe_path, class: "alert-link"
          to turn it on.
      - else
        - if current_user.mcp_security_requirements_met?
          %p.text-success
            You’re ready. Paste the URL into your MCP client and approve access when asked.
        - else
          %p
            Add a passkey or two-factor authentication on
            = succeed "," do
              = link_to "Account security", security_path
            then use the URL below.

        %p{style: "margin-bottom: 6px;"}
          %strong MCP server URL (Streamable HTTP)
        %pre{style: "white-space: pre-wrap;"}= mcp_server_url

    - if @oauth_applications.present?
      .well{style: "background-color: #E8E8E2; padding: 15px 20px; margin-top: 10px;"}
        %h4{style: "margin-top: 0;"} Connected apps
        %p.small.text-muted{style: "margin-bottom: 12px;"}
          These tools can call Dabble Me on your behalf until you revoke them.
        .table-responsive
          %table.table.table-striped{style: "margin-bottom: 0;"}
            %thead
              %tr
                %th= t("doorkeeper.authorized_applications.index.application")
                %th= t("doorkeeper.authorized_applications.index.created_at")
                %th
            %tbody
              - @oauth_applications.each do |application|
                %tr
                  %td= application.name
                  %td= application.created_at.strftime(date_fmt)
                  %td.text-right
                    = button_to t("doorkeeper.authorized_applications.buttons.revoke"),
                        oauth_authorized_application_path(application),
                        method: :delete,
                        class: "btn btn-default btn-sm",
                        data: { confirm: t("doorkeeper.authorized_applications.confirmations.revoke") }
