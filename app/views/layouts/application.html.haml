!!!
%html{ lang: I18n.locale.to_s }
  %head
    %title= yield_or_default :title, action_name.titlecase
    %meta{ charset: 'utf-8' }
    %meta{ httpEquiv: "Content-Type", content: "text/html; charset=ISO-8859-1"}
    %meta{ name: 'viewport', content: 'width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0' }
    %meta{ content: 'IE=edge', 'http-equiv' => 'X-UA-Compatible' }
    = csrf_meta_tags
    = yield :head
    = render 'shared/favicons_and_metatags'
    = stylesheet_link_tag '/application-tailwind.css', media: 'all'
    = stylesheet_link_tag 'application', media: 'all'
    = javascript_include_tag 'application'

    :javascript
      window.action = '#{@js_action}';

    / HTML5 shim and Respond.js IE8 support of HTML5 elements and media queries
    /[if lt IE 9]
      = javascript_include_tag '//oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js', 'respond.js'

    - if Rails.env.production?
      = javascript_include_tag "https://www.googletagmanager.com/gtag/js?id=#{ENV['GOOGLE_ANALYTICS_4_ID']}", async: true
      :javascript
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', "#{ENV['GOOGLE_ANALYTICS_4_ID']}", {
          'anonymize_ip': true
        });

  %body.bg-page.min-h-screen
    #wrap.min-h-screen
      = render 'shared/navbar'

      #main-container.mx-auto.max-w-6xl.px-4.pb-40.pt-16{class: "#{params[:controller].in?(['admin', 'payments', 'inspirations']) ? 'max-w-full' : ''}"}
        - if notice
          .mx-auto.mb-4.max-w-2xl
            .alert.alert-success= notice.html_safe
        - if alert && alert.class == Array
          - alert.each do |message|
            .mx-auto.mb-4.max-w-2xl
              .alert.alert-danger= message
        - elsif alert
          .mx-auto.mb-4.max-w-2xl
            .alert.alert-danger= alert.html_safe

        = yield

    = render 'shared/footer'
