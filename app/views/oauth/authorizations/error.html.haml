- title "Authorization — Dabble me."

.row
  .col-md-8.col-md-offset-2
    %p.text-muted{style: "margin-bottom: 4px;"} Dabble Me
    %h3{style: "margin-top: 0;"}= t("doorkeeper.authorizations.error.title")

    .well{style: "background-color: #E8E8E2; padding: 15px 20px; margin-top: 16px;"}
      %pre{style: "white-space: pre-wrap; border: none; background: transparent; padding: 0;"}
        = (local_assigns[:error_response] ? error_response : @pre_auth.error_response).body[:error_description]
